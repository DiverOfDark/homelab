.idea
.venv

# Terraform (we commit an encrypted tfstate.sops; plaintext must never be committed)
terraform/tfstate
terraform/.terraform/
.terraform/
terraform/*.tfstate
# tofu writes plaintext state backups with a .backup suffix that *.tfstate
# does NOT match — they contain every secret in state
terraform/*.backup
terraform/credentials*.tfvars
terraform/config.kubernetes.tfbackend